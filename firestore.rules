rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isTeacher() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isRoomHost(roomId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Games collection
    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacher();

      match /questions/{questionId} {
        allow read: if isAuthenticated();
        allow write: if isTeacher();
      }
    }

    // Rooms collection
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update, delete: if isRoomHost(roomId);

      match /players/{playerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == playerId;
        allow update: if isAuthenticated() && 
          (request.auth.uid == playerId || isRoomHost(roomId));
        allow delete: if isRoomHost(roomId);
      }

      match /answers/{answerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && 
          request.resource.data.playerId == request.auth.uid;
        allow update, delete: if isRoomHost(roomId);
      }

      match /results/{resultId} {
        allow read: if isAuthenticated();
        allow write: if isRoomHost(roomId);
      }
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isTeacher();
    }
  }
}
